VITE_APP_NAME=AUD-OS
VITE_APP_VERSION=0.1.0
VITE_APP_DESCRIPTION=A personal, neuro-intelligent, privacy-first web application for consciousness exploration
VITE_AUDIO_LATENCY_TARGET=<100ms
VITE_INDEXEDDB_NAME=AUDOS_IndexedDB
VITE_LOCAL_STORAGE_PREFIX=audos_

# Audio Configuration
VITE_DEFAULT_FREQUENCY=9
VITE_FREQUENCY_LADDER=3,6,9
VITE_BINAURAL_DIFFERENCE=9
VITE_PURE_TONE_MIN_HZ=100
VITE_PURE_TONE_MAX_HZ=400

# Timer Configuration
VITE_TIMER_OPTIONS=5,10,15,20,30
VITE_TIMER_UNIT=minutes

# Visualizer Configuration
VITE_ANIMATION_FRAME_RATE=60
VITE_PARALLAX_LAYERS=3
VITE_BLEND_MODES=overlay,multiiply,screen

# Storage Configuration
VITE_JOURNAL_DB_VERSION=1
VITE_SKETCH_DB_VERSION=1
VITE_SIGL_DB_VERSION=1
VITE_CODEX_DB_VERSION=1

# PWA Configuration
VITE_OFFLINE_ENABLED=true
VITE_CACHE_NAME=AUDOS_CACHE_V1
VITE_STATIC_ASSETS_CACHE=audos-static-v1